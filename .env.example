# Which provider to use by default: "openai", "anthropic", or "gemini"
PROVIDER=openai

# Fallback provider used automatically if the primary provider's call fails
FALLBACK_PROVIDER=anthropic

# API keys (leave the ones you don't use blank)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model names
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_MODEL=gemini-2.5-flash

# Embeddings: "openai" or "local" (sentence-transformers, no API key needed)
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chroma persistence directory
CHROMA_DIR=./chroma_store

# Response cache directory
CACHE_DIR=./cache_store

# Reliability
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=3
BATCH_CONCURRENCY=5
